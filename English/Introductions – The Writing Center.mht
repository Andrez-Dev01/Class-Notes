------MultipartBoundary--NDKFljNNVY3sQECHwDkUTTJYUfcCyiEVZoiDgUDXuC----
Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: https://writingcenter.unc.edu/wp-content/plugins/unc-cookie-banner/dist/cookie-banner.css?ver=22447759e5dd5bf1c282

@charset "utf-8";

body #cookie-banner { align-items: center; background-color: rgb(65, 65, 65); border-top: 1px solid rgb(81, 81, 81); bottom: 0px; color: rgb(255, 255, 255); display: none; font-family: Verdana, Arial, sans-serif; font-size: 16px; justify-content: center; left: 0px; line-height: 1; padding: 20px; position: fixed; right: 0px; z-index: 9999999; }

body #cookie-banner #container-cookie { align-items: center; display: flex; margin: 0px auto; max-width: 1170px; width: 100%; }

@media (max-width: 768px) {
  body #cookie-banner #container-cookie { align-items: stretch; flex-direction: column; }
}

body #cookie-banner a { color: rgb(255, 255, 255); text-decoration: underline; }

body #cookie-banner a:focus, body #cookie-banner a:hover { color: rgb(255, 255, 255); text-decoration: none; }

body #cookie-banner a:active { text-decoration: underline; }

body #cookie-banner .cookie-banner-text { line-height: 1.5; max-width: 100%; padding: 0px 30px 0px 0px; text-align: left; font-size: 13px !important; }

@media (max-width: 768px) {
  body #cookie-banner .cookie-banner-text { margin-bottom: 10px; margin-top: 0px; max-width: 100%; text-align: center; }
}

body #cookie-banner button.cookie-accept-button { background: none rgb(0, 127, 174); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 3px; box-shadow: none; color: rgb(255, 255, 255); cursor: pointer; font-family: Verdana, Arial, sans-serif; margin: 5px 10px; padding: 8px 10px; text-shadow: none; transition: background-color 0.5s; white-space: nowrap; font-size: 13px !important; }

body #cookie-banner button.cookie-accept-button:focus, body #cookie-banner button.cookie-accept-button:hover { background-color: rgb(0, 0, 0); }

body #cookie-banner button.cookie-accept-button:active { background-color: rgb(0, 127, 174); }
